# Copy to .env and fill in (.env is gitignored). Docker Compose loads it automatically.

# Public URL the app is served at — scheme + host, no trailing slash.
# Behind a reverse proxy this MUST match the real URL or form POSTs get a 403 (SvelteKit CSRF).
# Local testing example: http://localhost:8091
ORIGIN=https://roster.example.org

# Host port to publish (the container always listens on 3000).
ROSTER_PORT=8091

# Host directory holding the SQLite database (persists across rebuilds).
# Local default is ./data; on a server point this at a backed-up location.
ROSTER_DB_DIR=./data

# Event name shown in the app header (display only).
EVENT_NAME=Your parkrun

# Woodland dark palette: mossy (leaf green) | bark (amber/brown) | pine (blue-green). Default mossy.
THEME=mossy

# Roles this parkrun OFFERS IN THE POLL (comma-separated task ids). Unset = all standard roles.
# The generator still fills roles not listed here (via pairing), so this only limits what
# volunteers can request. Task ids:
#   1 Run Director · 2 Timekeeper · 7 Marshal · 11 Barcode Scanning · 13 Finish Tokens ·
#   15 First Timers Welcome · 19 Tail Walker · 34 Event Day Course Check
# Example (Clonbur: drop First Timers Welcome 15 + Finish Tokens 13 — always paired):
# POLL_ROLES=1,34,2,11,7,19
